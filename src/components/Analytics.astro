---
// Analytics component for Vercel Analytics, Speed Insights, and Umami
---

<!-- Umami Analytics -->
<script defer src="https://cloud.umami.is/script.js" data-website-id="c3416c41-9c5f-4df7-a82b-58b5e0efedc8"></script>

<!-- Vercel Analytics -->
<script>
  if (typeof window !== 'undefined' && import.meta.env.PROD) {
    import('@vercel/analytics').then(({ inject }) => {
      inject();
    });
  }
</script>

<!-- Vercel Speed Insights -->
<script>
  if (typeof window !== 'undefined' && import.meta.env.PROD) {
    import('@vercel/speed-insights').then(({ injectSpeedInsights }) => {
      injectSpeedInsights();
    });
  }
</script>